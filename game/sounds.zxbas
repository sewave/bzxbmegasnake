'Beeps the fruit sound
SUB fruitSound()
    BEEP .02, 10
END SUB

'Beeps the die sound
SUB dieSound()
    BEEP .1, 20
END SUB

'Beeps the start sound
SUB startSound()
    BEEP .4, 40
END SUB

'Beeps the ungrow sound
SUB ungrowSound()
    BEEP .02, 15
END SUB

'Beeps the speed up sound
SUB speedUpSound()
    BEEP .001, 12
    BEEP .001, 13
    BEEP .001, 14
END SUB

'Beeps the speed down sound
SUB speedDownSound()
    BEEP .001, 14
    BEEP .001, 13
    BEEP .001, 12
END SUB